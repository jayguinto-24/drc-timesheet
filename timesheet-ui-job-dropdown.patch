+// utils/jobNormalize.ts
+// Normalize various job input formats into canonical: PYY-MM-XXX
+export function normalizeJob(input: string): string | null {if (!input) return null;const s = input.toString().trim().toUpperCase();// remove spaceslet cleaned = s.replace(/\s+/g, '');// remove leading/non-alphanumeric except Pcleaned = cleaned.replace(/[^A-Z0-9-]/g, '');// If already looks like PYY-MM-XXX or PYYMMXXX or PYYYY... try to parse numbers// Extract digitsconst digits = cleaned.replace(/[^0-9]/g, '');// Attempt to find year (2 digits), month (1-2 digits), sequence (rest)if (cleaned.startsWith('P')) {const numeric = digits;if (numeric.length >= 4) { // assume first 2 = year, next 2 (or 1 if length ambiguous) = month, rest = seq

 const year = numeric.slice(0, 2);

 let month = numeric.slice(2, 4);

 let seq = numeric.slice(4);

 if (!seq) {

   // maybe month was 1 digit: take 3rd as seq start

   month = numeric.slice(2, 3);

   seq = numeric.slice(3) || '001';

 }

 month = month.padStart(2, '0');

 seq = seq.padStart(3, '0');

 return `P${year}-${month}-${seq}`;

}} else {// Cases like 25607 -> interpret as: 25 6 07 => P25-06-007if (digits.length >= 4) { const year = digits.slice(0, 2);

 // next 1-2 digits for month: choose 1 if remaining length equals 3, else 2

 const rem = digits.slice(2);

 let month = rem.length >= 3 ? rem.slice(0, rem.length - 2) : rem.slice(0, 1);

 let seq = rem.slice(month.length) || '1';

 month = month.padStart(2, '0');

 seq = seq.padStart(3, '0');

 return `P${year}-${month}-${seq}`;

}}// Last attempt: extract groups like P25-7-14 or P25-714const m = cleaned.match(/^P?(\d{2})-?(\d{1,2})-?(\d{1,3})$/);if (m) {const year = m[1];const month = m[2].padStart(2, '0');const seq = m[3].padStart(3, '0');return P${year}-${month}-${seq};}return null;
